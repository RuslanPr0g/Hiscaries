{
  "name": "hiscaries-client",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/hiscaries-client/src",
  "prefix": "app",
  "generators": {
    "@schematics/angular:component": {
      "style": "scss"
    }
  },
  "targets": {
    "build": {
      "executor": "@angular-devkit/build-angular:application",
      "options": {
        "outputPath": "dist/apps/hiscaries-client",
        "index": "apps/hiscaries-client/src/index.html",
        "browser": "apps/hiscaries-client/src/main.ts",
        "polyfills": [
          "zone.js"
        ],
        "tsConfig": "apps/hiscaries-client/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/hiscaries-client/public"
          },
          {
            "glob": "**/*",
            "input": "node_modules/ngx-extended-pdf-viewer/assets/",
            "output": "assets/"
          }
        ],
        "styles": [
          "node_modules/primeicons/primeicons.css",
          "apps/hiscaries-client/src/styles.scss"
        ],
        "scripts": []
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "4MB",
              "maximumError": "6MB"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "8kB",
              "maximumError": "15kB"
            }
          ],
          "outputHashing": "all",
          "optimization": true,
          "aot": true
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production",
      "outputs": [
        "{options.outputPath}"
      ]
    },
    "serve": {
      "executor": "@angular-devkit/build-angular:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "hiscaries-client:build:production"
        },
        "development": {
          "buildTarget": "hiscaries-client:build:development"
        }
      },
      "defaultConfiguration": "development",
      "options": {
        "proxyConfig": "proxy.conf.json"
      }
    },
    "extract-i18n": {
      "executor": "@angular-devkit/build-angular:extract-i18n"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}